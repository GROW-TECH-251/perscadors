# ============================================
# PERSCADORS - Exemple de Configuration Next.js
# ============================================
# Copiez ce fichier en .env.local et remplissez avec vos vraies valeurs.
# NE COMMITEZ JAMAIS le fichier .env.local dans Git.

# --------------------------------------------
# SUPABASE (Base de données + Auth + Storage)
# --------------------------------------------
# Récupérez ces valeurs depuis votre dashboard Supabase
# Settings > API > Project URL & anon public key

NEXT_PUBLIC_SUPABASE_URL=https://votre-projet.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=votre-cle-anon-ici

# --------------------------------------------
# WHATSAPP BUSINESS
# --------------------------------------------
# Numéro WhatsApp pour commandes et support client

NEXT_PUBLIC_WHATSAPP_PHONE_DIGITS=22967280018
NEXT_PUBLIC_WHATSAPP_PHONE_DISPLAY=+229 67 28 00 18

# --------------------------------------------
# AUTHENTIFICATION ADMIN
# --------------------------------------------
# Option 1: Supabase Auth (recommandé pour production)
# Créez un utilisateur dans Supabase > Authentication > Users
# Puis laissez ces lignes commentées

# NEXT_PUBLIC_ADMIN_LOGIN_ID=admin@perscadors.com
# NEXT_PUBLIC_ADMIN_PASSWORD=votre-mot-de-passe-secure

# Option 2: Auth démo locale (fallback si Supabase Auth non configuré)
NEXT_PUBLIC_ADMIN_LOGIN_ID=admin@perscadors.com
NEXT_PUBLIC_ADMIN_PASSWORD=perscadors2024

# --------------------------------------------
# GOOGLE ANALYTICS (Optionnel)
# --------------------------------------------
# ID de mesure GA4 pour le tracking analytics

NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# --------------------------------------------
# CONFIGURATION BOUTIQUE
# --------------------------------------------
NEXT_PUBLIC_SHOP_NAME=HP Collection
NEXT_PUBLIC_SHOP_CURRENCY=FCFA
NEXT_PUBLIC_SHOP_COUNTRY=Bénin